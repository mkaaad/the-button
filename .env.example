# 使用说明：先复制为项目根目录的 ".env"，再执行 docker compose。

# 阿里云短信配置
ACCESS_KEY_ID=your_access_key_id
ACCESS_KEY_SECRET=your_access_key_secret

# 后端容器使用的 Redis 配置
REDIS_PASSWORD=
REDIS_DB=0

# 游戏时间窗口（由后端强制校验）
# 支持格式：
# - 2006-01-02 15:04:05
# - 2006-01-02 15:04:05.999
# - RFC3339（例如 2026-02-16T20:00:00+08:00）
GAME_START_TIME=2026-02-16 20:00:00
GAME_END_TIME=2026-02-16 23:59:59.999
GAME_TIMEZONE=Asia/Shanghai
